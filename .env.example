DJANGO_SETTINGS_MODULE=selectora_project.settings.dev
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Production PostgreSQL
POSTGRES_DB=selectora
POSTGRES_USER=selectora
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Example: https://selectora.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true

# Email
DEFAULT_FROM_EMAIL=Selectora <noreply@selectora.example.com>
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_your_resend_api_key
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10

# Telegram bot integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
